{
  "extends": "../../tsconfig.app.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": "./",
    "paths": {
      "@breedhub/rxdb-store": ["../../packages/rxdb-store/src/index.ts"],
      "@breedhub/rxdb-store/*": ["../../packages/rxdb-store/src/*"],
      "@ui/*": ["../../packages/ui/*"],
      "@ui/components/*": ["../../packages/ui/components/*"],
      "@shared/*": ["../shared/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/mocks/**/*",
    "src/components/test/**/*",
    "src/core/api/mock.hooks.ts",
    "src/domain/breed/BreedNameComponent.tsx",
    "src/scripts/**/*"
  ]
}
